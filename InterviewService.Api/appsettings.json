{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2"
    }
  },
  "TextAI": {
    "ApiEndpoint": "https://polza.ai/api/v1",
    "ApiKey": "__TEXTAI_API_KEY__",
    "RetryAfter": "00:03:00",
    "RetryCount": 3
  },
  "ConnectionStrings": {
    "Redis": "interview-redis:6379",
    "Postgres": "Host=interview-postgres;Port=5432;Database=fitflow_interviews;Username=postgres;Password=postgres"
  },
  "Archiving": {
    "InactiveAfter": "00:30:00",
    "SweepInterval": "00:05:00",
    "BatchSize": 100
  },
  "AIModels": {
    "defaultModel": {
      "modelAlias": "GPT-OSS 120B",
      "modelName": "openai/gpt-oss-120b",
      "supportsJsonOutput": true,
      "supportsFunctionCalling": true
    },
    "alternativeModels": [
      {
        "modelAlias": "GPT-OSS 20B",
        "modelName": "openai/gpt-oss-20b",
        "supportsJsonOutput": true,
        "supportsFunctionCalling": true
      },
      {
        "modelAlias": "Kimi K2.5",
        "modelName": "moonshotai/Kimi-K2.5",
        "supportsJsonOutput": true,
        "supportsFunctionCalling": true
      },
      {
        "modelAlias": "Qwen 3.5 397B A17B",
        "modelName": "Qwen/Qwen3.5-397B-A17B",
        "supportsJsonOutput": true,
        "supportsFunctionCalling": true
      },
      {
        "modelAlias": "Gemma 4 31B",
        "modelName": "google/gemma-4-31b-it",
        "supportsJsonOutput": true,
        "supportsFunctionCalling": false
      },
      {
        "modelAlias": "Grok 4.20",
        "modelName": "x-ai/grok-4.20",
        "supportsJsonOutput": true,
        "supportsFunctionCalling": false
      },
      {
        "modelAlias": "Gemini 2.5 Flash Lite",
        "modelName": "google/gemini-2.5-flash-lite",
        "supportsJsonOutput": true,
        "supportsFunctionCalling": false
      },
      {
        "modelAlias": "GLM 4.5 Air",
        "modelName": "z-ai/glm-4.5-air",
        "supportsJsonOutput": true,
        "supportsFunctionCalling": false
      }
    ]
  }
}
